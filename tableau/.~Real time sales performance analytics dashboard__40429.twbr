      </column>
      <column caption='KPI - Profit Margin %' datatype='real' default-format='p0.0%' name='[Calculation_2533013170794501]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([total_amount]) * 100' />
      </column>
      <column caption='KPI - Conversion Rate %' datatype='real' name='[Calculation_2533013171310598]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customer_id]) / TOTAL(COUNTD([customer_id])) * 100'>
          <table-calc ordering-type='Rows' />
